@page "/account"
@inject ApiClient Api
@inject AppState AppState
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-6">Mitt konto</MudText>
<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardContent Class="pa-5">
                <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                    <MudAvatar Color="Color.Primary" Style="height:80px;width:80px;font-size:2rem;">@(AppState.UserFullName?[0] ?? '?')</MudAvatar>
                    <MudText Typo="Typo.h6">@AppState.UserFullName</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@AppState.UserEmail</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@AppState.UserRole</MudChip>
                </MudStack>
                <MudDivider Class="my-3" />
                <MudList T="string" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.Business">@AppState.OrganizationName</MudListItem>
                </MudList>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="5">
        <MudCard Elevation="2">
            <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Byt lösenord</MudText></CardHeaderContent></MudCardHeader>
            <MudCardContent>
                @if (!string.IsNullOrEmpty(_error)) { <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert> }
                <MudTextField @bind-Value="_currentPw" Label="Nuvarande lösenord"
                              InputType="@(_showCurrent ? InputType.Text : InputType.Password)" Variant="Variant.Outlined"
                              Adornment="Adornment.End" AdornmentIcon="@(_showCurrent ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showCurrent = !_showCurrent)" Class="mb-3" />
                <MudTextField @bind-Value="_newPw" Label="Nytt lösenord (minst 10 tecken)"
                              InputType="@(_showNew ? InputType.Text : InputType.Password)" Variant="Variant.Outlined"
                              Adornment="Adornment.End" AdornmentIcon="@(_showNew ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showNew = !_showNew)" Class="mb-3" />
                <MudTextField @bind-Value="_confirmPw" Label="Bekräfta nytt lösenord"
                              InputType="@(_showConfirm ? InputType.Text : InputType.Password)" Variant="Variant.Outlined"
                              Adornment="Adornment.End" AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showConfirm = !_showConfirm)" Class="mb-4" />
            </MudCardContent>
            <MudCardActions Class="px-4 pb-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Lock"
                           OnClick="ChangePasswordAsync" Disabled="_saving">
                    @(_saving ? "Sparar…" : "Byt lösenord")
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _currentPw = string.Empty, _newPw = string.Empty, _confirmPw = string.Empty;
    private bool   _saving, _showCurrent, _showNew, _showConfirm;
    private string? _error;

    private async Task ChangePasswordAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_currentPw) || string.IsNullOrWhiteSpace(_newPw)) { _error = "Fyll i alla fält."; return; }
        if (_newPw.Length < 10) { _error = "Nytt lösenord måste vara minst 10 tecken."; return; }
        if (_newPw != _confirmPw) { _error = "Lösenorden matchar inte."; return; }
        _saving = true;
        try
        {
            var res = await Api.ChangePasswordAsync(new ChangePasswordRequest { CurrentPassword = _currentPw, NewPassword = _newPw });
            if (res.Success) { Snackbar.Add("Lösenordet har ändrats.", Severity.Success); _currentPw = _newPw = _confirmPw = string.Empty; }
            else { _error = res.Errors.FirstOrDefault() ?? "Det gick inte att byta lösenord."; }
        }
        finally { _saving = false; }
    }
}
