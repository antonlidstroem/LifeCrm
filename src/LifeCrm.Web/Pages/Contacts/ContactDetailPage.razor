@page "/contacts/{Id:guid}"
@inject ApiClient Api
@inject AppState AppState
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/contacts"))" />
    <MudText Typo="Typo.h5">@(_contact?.Name ?? "Laddar…")</MudText>
    <MudSpacer />
    @if (AppState.CanWrite && _contact is not null)
    { <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenEditDialog">Redigera</MudButton> }
</MudStack>

@if (_loading) { <MudProgressLinear Color="Color.Primary" Indeterminate="true" /> }
else if (_contact is not null)
{
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                        <MudAvatar Color="Color.Primary" Style="height:90px;width:90px;font-size:2rem;">@_contact.Name[0]</MudAvatar>
                        <MudText Typo="Typo.h5" Class="mt-3">@_contact.Name</MudText>
                        <MudChip T="string" Color="@_contact.Type.ToMudColor()" Size="Size.Small" Variant="Variant.Text">@_contact.Type</MudChip>
                    </MudStack>
                    <MudDivider Class="my-3" />
                    <MudList T="string" Dense="true">
                        <MudListItem Icon="@Icons.Material.Filled.Email">@(_contact.Email ?? "Ingen e-post")</MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Phone">@(_contact.Phone ?? "Inget nummer")</MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.LocationOn">@(string.Join(", ", new[] { _contact.City, _contact.Country }.Where(s => !string.IsNullOrEmpty(s))))</MudListItem>
                        @if (!string.IsNullOrEmpty(_contact.Tags)) { <MudListItem Icon="@Icons.Material.Filled.Label">@_contact.Tags</MudListItem> }
                    </MudList>
                    <MudDivider Class="my-3" />
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <div><MudText Typo="Typo.caption" Color="Color.Secondary">Gåvor</MudText><MudText Typo="Typo.h6">@_contact.DonationCount</MudText></div>
                        <div><MudText Typo="Typo.caption" Color="Color.Secondary">Totalt</MudText><MudText Typo="Typo.h6">$@_contact.TotalDonated.ToString("N2")</MudText></div>
                    </MudStack>
                    @if (!string.IsNullOrEmpty(_contact.Notes)) { <MudDivider Class="my-3" /><MudText Typo="Typo.caption" Color="Color.Secondary">Anteckningar</MudText><MudText Typo="Typo.body2" Class="mt-1">@_contact.Notes</MudText> }
                    @if (AppState.IsFinanceOrAdmin)
                    {
                        <MudDivider Class="my-3" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddCard" FullWidth="true" OnClick="OpenDonationDialog">Registrera gåva</MudButton>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <MudTabPanel Text="Tidslinje" Icon="@Icons.Material.Filled.History">
                    @if (AppState.CanWrite)
                    { <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mb-4" OnClick="OpenLogInteractionDialog">Logga interaktion</MudButton> }
                    @if (!_interactions.Any()) { <EmptyState Title="Inga interaktioner" Description="Logga ett samtal, e-post eller möte." Icon="@Icons.Material.Outlined.History" /> }
                    else
                    {
                        <MudTimeline TimelinePosition="TimelinePosition.Start">
                            @foreach (var i in _interactions.OrderByDescending(x => x.OccurredAt))
                            {
                                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                                    <ItemContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Start">
                                            <div style="flex:1">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">@i.Type</MudChip>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@i.OccurredAt.ToString("g")</MudText>
                                                </MudStack>
                                                <MudText Typo="Typo.body2">@i.Body</MudText>
                                            </div>
                                            @if (AppState.CanWrite) { <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => DeleteInteraction(i.Id))" /> }
                                        </MudStack>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    }
                </MudTabPanel>
                <MudTabPanel Text="Gåvor" Icon="@Icons.Material.Filled.AttachMoney">
                    @if (!_donations.Any()) { <EmptyState Title="Inga gåvor registrerade" Icon="@Icons.Material.Outlined.AttachMoney" /> }
                    else
                    {
                        <MudTable T="DonationListDto" Items="_donations" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent><MudTh>Datum</MudTh><MudTh>Belopp</MudTh><MudTh>Projekt</MudTh><MudTh>Status</MudTh><MudTh Style="width:110px"></MudTh></HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Date.ToString("yyyy-MM-dd")</MudTd>
                                <MudTd>$@context.Amount.ToString("N2")</MudTd>
                                <MudTd>@(context.ProjectName ?? "—")</MudTd>
                                <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@context.Status.ToMudColor()">@context.Status</MudChip></MudTd>
                                <MudTd Style="white-space:nowrap">
                                    @if (AppState.IsFinanceOrAdmin)
                                    {
                                        <MudTooltip Text="Generera och skicka kvitto"><MudIconButton Icon="@Icons.Material.Filled.Email" Size="Size.Small" OnClick="@(() => SendReceipt(context.Id))" /></MudTooltip>
                                        @if (context.ReceiptSent)
                                        { <MudTooltip Text="Ladda ner kvitto"><MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Size="Size.Small" Color="Color.Primary" OnClick="@(() => DownloadReceipt(context.Id, context.ReceiptDocumentId))" /></MudTooltip> }
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private ContactDto? _contact = null;
    private IReadOnlyList<DonationListDto> _donations    = Array.Empty<DonationListDto>();
    private IReadOnlyList<InteractionDto>  _interactions = Array.Empty<InteractionDto>();
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var t1 = Api.GetContactAsync(Id);
        var t2 = Api.GetDonationsAsync(new PaginationParams { PageSize = 100 }, contactId: Id);
        var t3 = Api.GetInteractionsAsync(Id);
        await Task.WhenAll(t1, t2, t3);
        _contact      = t1.Result.Data;
        _donations    = t2.Result.Data?.Items ?? Array.Empty<DonationListDto>();
        _interactions = t3.Result.Data ?? Array.Empty<InteractionDto>();
        _loading      = false;
    }

    private async Task OpenEditDialog()
    {
        var d = DialogService.Show<ContactFormDialog>("Redigera", new DialogParameters { ["ContactId"] = Id }, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task OpenDonationDialog()
    {
        var d = DialogService.Show<DonationFormDialog>("Registrera gåva", new DialogParameters { ["PresetContactId"] = Id }, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task OpenLogInteractionDialog()
    {
        var d = DialogService.Show<LogInteractionDialog>("Logga interaktion", new DialogParameters { ["ContactId"] = Id }, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task DeleteInteraction(Guid interactionId)
    {
        var p = new DialogParameters { ["Title"] = "Ta bort interaktion", ["Message"] = "Är du säker?" };
        var confirm = DialogService.Show<ConfirmDialog>("", p);
        if ((await confirm.Result).Canceled) return;
        var res = await Api.DeleteInteractionAsync(interactionId);
        if (res.Success) { Snackbar.Add("Borttagen.", Severity.Success); await LoadAsync(); }
        else Snackbar.Add(res.Errors.FirstOrDefault() ?? "Fel.", Severity.Error);
    }

    private async Task SendReceipt(Guid donationId)
    {
        var res = await Api.GenerateReceiptAsync(donationId, sendByEmail: true);
        if (res.Success) { Snackbar.Add("Kvitto skickat.", Severity.Success); await LoadAsync(); }
        else Snackbar.Add(res.Errors.FirstOrDefault() ?? "Fel.", Severity.Error);
    }

    private async Task DownloadReceipt(Guid donationId, Guid? documentId)
    {
        var res = documentId.HasValue
            ? await Api.DownloadReceiptAsync(donationId, documentId.Value)
            : await Api.DownloadLatestReceiptAsync(donationId);
        if (!res.Success) Snackbar.Add(res.Errors.FirstOrDefault() ?? "Nedladdning misslyckades.", Severity.Error);
    }
}
