@page "/projects"
@using LifeCrm.Web.Components.Dialogs
@using LifeCrm.Web.Components.Shared
@inject ApiClient Api
@inject AppState AppState
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Projekt</MudText>
    <MudSpacer />
    @if (AppState.CanWrite)
    { <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">Nytt projekt</MudButton> }
</MudStack>

<MudTextField T="string"
              Value="_search"
              ValueChanged="OnSearchChanged"
              Placeholder="Sök projekt…"
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Search"
              Variant="Variant.Outlined"
              Immediate="true"
              DebounceInterval="350"
              Clearable="true"
              Class="mb-4" />

<MudTable T="ProjectListDto"
          ServerData="ServerReload"
          @ref="_table"
          Hover="true" Dense="true"
          OnRowClick="@((TableRowClickEventArgs<ProjectListDto> e) => Nav.NavigateTo($"/projects/{e.Item.Id}"))">
    <HeaderContent>
        <MudTh>Namn</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Plats</MudTh>
        <MudTh>Finansierat</MudTh>
        <MudTh>Mål</MudTh>
        <MudTh Style="width:90px"></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@context.Status.ToMudColor()">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd>@(context.Location ?? "—")</MudTd>
        <MudTd>$@context.TotalFunded.ToString("N2")</MudTd>
        <MudTd>@(context.BudgetGoal.HasValue ? $"${context.BudgetGoal:N2}" : "—")</MudTd>
        <MudTd Style="white-space:nowrap" @onclick:stopPropagation="true">
            @if (AppState.CanWrite)
            { <MudIconButton Icon="@Icons.Material.Filled.Edit"   Size="Size.Small"              OnClick="@(() => OpenEditDialog(context))" /> }
            @if (AppState.IsAdmin)
            { <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteProject(context))" /> }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <EmptyState Title="Inga projekt ännu" Icon="@Icons.Material.Outlined.FolderOpen"
                    Description="Skapa ett projekt för att koppla gåvor till specifika ändamål.">
            <ActionContent>
                @if (AppState.CanWrite)
                { <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialog">Skapa projekt</MudButton> }
            </ActionContent>
        </EmptyState>
    </NoRecordsContent>
    <LoadingContent><LoadingSkeleton Rows="6" /></LoadingContent>
    <PagerContent><MudTablePager PageSizeOptions="new int[]{25, 50}" /></PagerContent>
</MudTable>

@code {
    private MudTable<ProjectListDto>? _table;
    private string _search = string.Empty;

    private async Task<TableData<ProjectListDto>> ServerReload(TableState state, CancellationToken ct)
    {
        var res = await Api.GetProjectsAsync(new PaginationParams
        {
            Page          = state.Page + 1,
            PageSize      = state.PageSize,
            Search        = _search,
            SortAscending = state.SortDirection != MudBlazor.SortDirection.Descending
        });
        var paged = res.Data;
        return new TableData<ProjectListDto>
        {
            Items      = paged?.Items ?? Array.Empty<ProjectListDto>(),
            TotalItems = paged?.TotalCount ?? 0
        };
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        if (_table is not null) await _table.ReloadServerData();
    }

    private async Task OpenCreateDialog()
    {
        var d = DialogService.Show<ProjectFormDialog>("Nytt projekt",
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        if (!(await d.Result).Canceled && _table is not null)
            await _table.ReloadServerData();
    }

    private async Task OpenEditDialog(ProjectListDto p)
    {
        var d = DialogService.Show<ProjectFormDialog>("Redigera",
            new DialogParameters { ["ProjectId"] = p.Id },
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        if (!(await d.Result).Canceled && _table is not null)
            await _table.ReloadServerData();
    }

    private async Task DeleteProject(ProjectListDto project)
    {
        var p = new DialogParameters { ["Title"] = "Ta bort projekt", ["Message"] = $"Ta bort {project.Name}?" };
        var confirm = DialogService.Show<ConfirmDialog>("", p);
        if ((await confirm.Result).Canceled) return;
        var res = await Api.DeleteProjectAsync(project.Id);
        if (res.Success) { Snackbar.Add("Borttaget.", Severity.Success); if (_table is not null) await _table.ReloadServerData(); }
        else Snackbar.Add(res.Errors.FirstOrDefault() ?? "Fel.", Severity.Error);
    }
}
