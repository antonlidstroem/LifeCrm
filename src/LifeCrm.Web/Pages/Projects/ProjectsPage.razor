@page "/projects"
@inject ApiClient Api
@inject AppState AppState
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Projekt</MudText>
    <MudSpacer />
    @if (AppState.CanWrite) { <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">Nytt projekt</MudButton> }
</MudStack>

@if (_loading) { <LoadingSkeleton Rows="6" /> }
else if (!_projects.Any())
{
    <EmptyState Title="Inga projekt ännu" Icon="@Icons.Material.Outlined.FolderOpen" Description="Skapa ett projekt för att koppla gåvor till specifika ändamål.">
        <ActionContent>@if (AppState.CanWrite) { <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialog">Skapa projekt</MudButton> }</ActionContent>
    </EmptyState>
}
else
{
    <MudTable T="ProjectListDto" Items="_projects" Hover="true" Dense="true"
              OnRowClick="@((TableRowClickEventArgs<ProjectListDto> e) => Nav.NavigateTo($"/projects/{e.Item.Id}"))">
        <HeaderContent><MudTh>Namn</MudTh><MudTh>Status</MudTh><MudTh>Plats</MudTh><MudTh>Finansierat</MudTh><MudTh>Mål</MudTh><MudTh Style="width:90px"></MudTh></HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@context.Status.ToMudColor()">@context.Status</MudChip></MudTd>
            <MudTd>@(context.Location ?? "—")</MudTd>
            <MudTd>$@context.TotalFunded.ToString("N2")</MudTd>
            <MudTd>@(context.BudgetGoal.HasValue ? $"${context.BudgetGoal:N2}" : "—")</MudTd>
            <MudTd Style="white-space:nowrap" @onclick:stopPropagation="true">
                @if (AppState.CanWrite) { <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" /> }
                @if (AppState.IsAdmin)  { <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteProject(context))" /> }
            </MudTd>
        </RowTemplate>
        <PagerContent><MudTablePager PageSizeOptions="new int[]{25,50}" /></PagerContent>
    </MudTable>
}

@code {
    private IReadOnlyList<ProjectListDto> _projects = Array.Empty<ProjectListDto>();
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() { _loading = true; var res = await Api.GetProjectsAsync(new PaginationParams { PageSize = 100 }); _projects = res.Data?.Items ?? Array.Empty<ProjectListDto>(); _loading = false; }

    private async Task OpenCreateDialog() { var d = DialogService.Show<ProjectFormDialog>("Nytt projekt", new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true }); if (!(await d.Result).Canceled) await LoadAsync(); }
    private async Task OpenEditDialog(ProjectListDto p) { var d = DialogService.Show<ProjectFormDialog>("Redigera", new DialogParameters { ["ProjectId"] = p.Id }, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true }); if (!(await d.Result).Canceled) await LoadAsync(); }

    private async Task DeleteProject(ProjectListDto project)
    {
        var p = new DialogParameters { ["Title"] = "Ta bort projekt", ["Message"] = $"Ta bort {project.Name}?" };
        var confirm = DialogService.Show<ConfirmDialog>("", p);
        if ((await confirm.Result).Canceled) return;
        var res = await Api.DeleteProjectAsync(project.Id);
        if (res.Success) { Snackbar.Add("Borttaget.", Severity.Success); await LoadAsync(); }
        else Snackbar.Add(res.Errors.FirstOrDefault() ?? "Fel.", Severity.Error);
    }
}
