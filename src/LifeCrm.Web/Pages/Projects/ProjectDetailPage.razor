@page "/projects/{Id:guid}"
@inject ApiClient Api
@inject AppState AppState
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/projects"))" />
    <MudText Typo="Typo.h5">@(_project?.Name ?? "Laddar…")</MudText>
    <MudSpacer />
    @if (AppState.CanWrite && _project is not null) { <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenEditDialog">Redigera</MudButton> }
</MudStack>

@if (_loading) { <MudProgressLinear Color="Color.Primary" Indeterminate="true" /> }
else if (_project is not null)
{
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@_project.Status.ToMudColor()" Class="mb-3">@_project.Status</MudChip>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-3">
                        <div><MudText Typo="Typo.caption" Color="Color.Secondary">Finansierat</MudText><MudText Typo="Typo.h6">$@_project.TotalFunded.ToString("N2")</MudText></div>
                        <div><MudText Typo="Typo.caption" Color="Color.Secondary">Mål</MudText><MudText Typo="Typo.h6">@(_project.BudgetGoal.HasValue ? $"${_project.BudgetGoal:N2}" : "—")</MudText></div>
                    </MudStack>
                    @if (!string.IsNullOrEmpty(_project.Location)) { <MudList T="string" Dense="true"><MudListItem Icon="@Icons.Material.Filled.LocationOn">@_project.Location</MudListItem></MudList> }
                    @if (!string.IsNullOrEmpty(_project.Description)) { <MudDivider Class="my-3" /><MudText Typo="Typo.caption" Color="Color.Secondary">Beskrivning</MudText><MudText Typo="Typo.body2" Class="mt-1">@_project.Description</MudText> }
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="8">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <MudTabPanel Text="Gåvor" Icon="@Icons.Material.Filled.AttachMoney">
                    @if (!_donations.Any()) { <EmptyState Title="Inga gåvor kopplade" Icon="@Icons.Material.Outlined.AttachMoney" /> }
                    else
                    {
                        <MudTable T="DonationListDto" Items="_donations" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent><MudTh>Datum</MudTh><MudTh>Givare</MudTh><MudTh>Belopp</MudTh><MudTh>Status</MudTh></HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Date.ToString("yyyy-MM-dd")</MudTd>
                                <MudTd><MudLink Href="@($"/contacts/{context.ContactId}")">@context.ContactName</MudLink></MudTd>
                                <MudTd>$@context.Amount.ToString("N2")</MudTd>
                                <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@context.Status.ToMudColor()">@context.Status</MudChip></MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>
                <MudTabPanel Text="Interaktioner" Icon="@Icons.Material.Filled.Chat">
                    @if (AppState.CanWrite) { <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mb-4" OnClick="OpenLogInteractionDialog">Logga interaktion</MudButton> }
                    <EmptyState Title="Interaktioner" Icon="@Icons.Material.Outlined.Chat" Description="Använd Logga-knappen ovan för att lägga till interaktioner kopplade till detta projekt." />
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private ProjectDto? _project = null;
    private IReadOnlyList<DonationListDto> _donations = Array.Empty<DonationListDto>();
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var t1 = Api.GetProjectAsync(Id);
        var t2 = Api.GetDonationsAsync(new PaginationParams { PageSize = 200 });
        await Task.WhenAll(t1, t2);
        _project   = t1.Result.Data;
        _donations = t2.Result.Data?.Items.Where(d => d.ProjectName == _project?.Name).ToList() ?? new List<DonationListDto>();
        _loading   = false;
    }

    private async Task OpenEditDialog()
    {
        var d = DialogService.Show<ProjectFormDialog>("Redigera", new DialogParameters { ["ProjectId"] = Id }, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task OpenLogInteractionDialog()
    {
        var d = DialogService.Show<LogInteractionDialog>("Logga interaktion", new DialogParameters { ["ProjectId"] = Id }, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        if (!(await d.Result).Canceled) await LoadAsync();
    }
}
