<MudStack AlignItems="AlignItems.Center" Class="pa-8">
    <MudIcon Icon="@Icon" Style="font-size: 3rem;" Color="Color.Default" Class="mb-2" />
    @if (!string.IsNullOrEmpty(Title))   { <MudText Typo="Typo.h6">@Title</MudText> }
    @if (!string.IsNullOrEmpty(Description)) { <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">@Description</MudText> }
    @if (ActionContent is not null) { <div class="mt-2">@ActionContent</div> }
</MudStack>

@code {
    [Parameter] public string          Title         { get; set; } = "Inget att visa";
    [Parameter] public string          Description   { get; set; } = string.Empty;
    [Parameter] public string          Icon          { get; set; } = Icons.Material.Filled.Inbox;
    [Parameter] public RenderFragment? ActionContent { get; set; }
}
