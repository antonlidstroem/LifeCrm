@inject ApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.AddComment" Class="mr-2 mb-n1" />Logga interaktion</MudText></TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_type" Label="Typ *" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Call")">Telefonsamtal</MudSelectItem>
                    <MudSelectItem Value="@("Email")">E-post</MudSelectItem>
                    <MudSelectItem Value="@("Meeting")">Möte</MudSelectItem>
                    <MudSelectItem Value="@("Note")">Anteckning</MudSelectItem>
                    <MudSelectItem Value="@("Other")">Övrigt</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6"><MudDatePicker @bind-Date="_date" Label="Datum *" Variant="Variant.Outlined" Editable="true" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_subject" Label="Ämne" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_body" Label="Beskrivning *" Variant="Variant.Outlined" Lines="4" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Avbryt</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_saving">@(_saving ? "Sparar…" : "Logga")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Guid? ContactId { get; set; }
    [Parameter] public Guid? ProjectId { get; set; }
    private string _type = "Note", _subject = string.Empty, _body = string.Empty;
    private DateTime? _date = DateTime.Today;
    private bool _saving;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_body)) { Snackbar.Add("Beskrivning är obligatorisk.", Severity.Warning); return; }
        _saving = true;
        try
        {
            var req = new CreateInteractionRequest { ContactId = ContactId, ProjectId = ProjectId, Type = Enum.Parse<InteractionType>(_type), OccurredAt = _date.HasValue ? new DateTimeOffset(_date.Value, TimeSpan.Zero) : DateTimeOffset.UtcNow, Subject = _subject.NullIfEmpty(), Body = _body };
            var res = await Api.CreateInteractionAsync(req);
            if (res.Success) { Snackbar.Add("Loggad.", Severity.Success); MudDialog.Close(DialogResult.Ok(true)); }
            else Snackbar.Add(res.Errors.FirstOrDefault() ?? "Fel.", Severity.Error);
        }
        finally { _saving = false; }
    }
    private void Cancel() => MudDialog.Cancel();
}
